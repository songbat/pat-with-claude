<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:AvaloniaClaudePet.Controls"
        x:Class="AvaloniaClaudePet.Views.PetWindow"
        Title="Claude Pet"
        Width="160" Height="180"
        SystemDecorations="None"
        ShowInTaskbar="False"
        x:CompileBindings="False">

    <Panel>
        <Border CornerRadius="16"
                Background="#40FFFFFF"
                BoxShadow="0 4 16 0 #40000000"
                ClipToBounds="True">
            <Grid RowDefinitions="*,Auto" Margin="8">
                <ctrl:PetControl Grid.Row="0"
                                 Expression="{Binding CurrentExpression}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1"
                           Text="{Binding CurrentState}"
                           HorizontalAlignment="Center"
                           FontSize="10"
                           Foreground="#80000000"
                           Margin="0,0,0,4"/>
            </Grid>
        </Border>

        <Panel Background="Transparent"
               x:Name="DragHandle"
               Cursor="SizeAll"/>
    </Panel>
</Window>
